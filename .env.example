# Скопируй этот файл в .env.local и подставь свои ключи.
# .env.local в .gitignore — туда складываем секреты.

# Mistral — embeddings (mistral-embed) для поиска по чату сообщества
MISTRAL_API_KEY=

# OpenRouter — LLM (ответы ассистента + разбор записей об обслуживании)
OPENROUTER_API_KEY=

# Supabase — база (треды + история машины). Используется ТОЛЬКО service_role на сервере.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# PIN для записи/правки истории машины (заголовок X-Admin-Key).
# Без этой переменной запись в БД полностью запрещена.
ADMIN_KEY=

# Необязательно (локальная разработка на Windows): принудить транспорт HTTP.
# "curl" — обойти TLS-fingerprint Cloudflare; "fetch" — стандартный fetch.
# HTTP_FORCE=curl

# Необязательно (локальная разработка): OpenRouter недоступен с RU-IP,
# серверный curl пускаем через локальный прокси VPN-клиента (порт смотри в его настройках).
# HTTPS_PROXY=http://127.0.0.1:3067
