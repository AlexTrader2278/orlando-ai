# Скопируй этот файл в .env.local и подставь свои ключи.
# .env.local в .gitignore — туда складываем секреты.

# Jina AI — для embeddings (https://jina.ai/embeddings/)
JINA_API_KEY=

# OpenRouter — для LLM (Perplexity, GPT-4o-mini, и т.д.)
OPENROUTER_API_KEY=

# Supabase — добавим когда создадим проект
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
